# ── Landrush Backend API ──────────────────────────────────────────
# Leave empty to use built-in mock data (no backend required).
EXPO_PUBLIC_API_URL=

# ── Google Maps ───────────────────────────────────────────────────
# Create keys at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps SDK for Android, Maps SDK for iOS
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# ── Google OAuth (Sign-In) ────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# - Web client ID:     Application type = Web application
# - iOS client ID:     Application type = iOS, Bundle ID = com.landrush.app
# - Android client ID: Application type = Android, Package = com.landrush.app
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ── Prembly / Identitypass (NIN verification) ────────────────────
EXPO_PUBLIC_PREMBLY_APP_ID=your-app-id-here
EXPO_PUBLIC_PREMBLY_API_KEY=your-api-key-here

# Change to true to call the real Prembly/NIMC API
EXPO_PUBLIC_USE_LIVE_NIN=false
