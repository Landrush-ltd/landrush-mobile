# ── Landrush Backend API ──────────────────────────────────────────
# Leave empty to use built-in mock data (no backend required).
# Set to your deployed API URL to enable real API calls.
EXPO_PUBLIC_API_URL=

# ── Prembly / Identitypass (NIN verification) ────────────────────
EXPO_PUBLIC_PREMBLY_APP_ID=your-app-id-here
EXPO_PUBLIC_PREMBLY_API_KEY=your-api-key-here

# Change to true to call the real Prembly/NIMC API
EXPO_PUBLIC_USE_LIVE_NIN=false
