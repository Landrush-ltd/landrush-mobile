# Backend API Configuration
# Leave empty to use mock data; set to your backend URL to use real API
EXPO_PUBLIC_API_URL=

# Google Maps API Keys (build-time, no EXPO_PUBLIC_ prefix)
# Get these from Google Cloud Console > APIs & Services > Credentials
# See SETUP_GOOGLE_CLOUD.md for detailed instructions
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# Google OAuth 2.0 Client IDs (runtime, requires EXPO_PUBLIC_ prefix)
# Get these from Google Cloud Console > APIs & Services > Credentials
# See SETUP_GOOGLE_CLOUD.md for detailed instructions
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Prembly NIN Verification (optional)
# Get from https://prembly.com
EXPO_PUBLIC_PREMBLY_APP_ID=
EXPO_PUBLIC_PREMBLY_API_KEY=
EXPO_PUBLIC_USE_LIVE_NIN=false
